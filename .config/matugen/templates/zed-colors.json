        "created.background": "{{colors.primary.default.hex}}22",
        "created.border": "{{colors.primary.default.hex}}",
        "deleted": "{{colors.error.default.hex}}",
        "deleted.background": "{{colors.error.default.hex}}22",
        "deleted.border": "{{colors.error.default.hex}}",
        "error": "{{colors.error.default.hex}}",
        "error.background": "{{colors.error.default.hex}}22",
        "error.border": "{{colors.error.default.hex}}",
        "hidden": "{{colors.outline.default.hex}}",
        "hidden.background": "{{colors.surface.default.hex}}",
        "hidden.border": "{{colors.outline_variant.default.hex}}",
        "hint": "{{colors.tertiary.default.hex}}",
        "hint.background": "{{colors.tertiary.default.hex}}22",
        "hint.border": "{{colors.tertiary.default.hex}}",
        "ignored": "{{colors.outline.default.hex}}",
        "ignored.background": "{{colors.surface.default.hex}}",
        "ignored.border": "{{colors.outline_variant.default.hex}}",
        "info": "{{colors.secondary.default.hex}}",
        "info.background": "{{colors.secondary.default.hex}}22",
        "info.border": "{{colors.secondary.default.hex}}",
        "modified": "#ffa726",
        "modified.background": "#ffa72622",
        "modified.border": "#ffa726",
        "predictive": "{{colors.outline.default.hex}}",
        "predictive.background": "{{colors.outline.default.hex}}22",
        "predictive.border": "{{colors.outline.default.hex}}",
        "renamed": "{{colors.secondary.default.hex}}",
        "renamed.background": "{{colors.secondary.default.hex}}22",
        "renamed.border": "{{colors.secondary.default.hex}}",
        "success": "{{colors.primary.default.hex}}",
        "success.background": "{{colors.primary.default.hex}}22",
        "success.border": "{{colors.primary.default.hex}}",
        "unreachable": "{{colors.outline.default.hex}}",
        "unreachable.background": "{{colors.surface.default.hex}}",
        "unreachable.border": "{{colors.outline_variant.default.hex}}",
        "warning": "#ffa726",
        "warning.background": "#ffa72622",
        "warning.border": "#ffa726",

        "players": [
          {
            "cursor": "{{colors.primary.default.hex}}",
            "background": "{{colors.primary.default.hex}}",
            "selection": "{{colors.primary.default.hex}}33"
          },
          {
            "cursor": "#26c6da",
            "background": "#26c6da",
            "selection": "#26c6da33"
          },
          {
            "cursor": "#ff0066",
            "background": "#ff0066",
            "selection": "#ff006633"
          },
          {
            "cursor": "#ffa726",
            "background": "#ffa726",
            "selection": "#ffa72633"
          }
        ],

        "syntax": {
          "attribute": { "color": "#26c6da" },
          "boolean": { "color": "#ff0066" },
          "comment": { "color": "#4a5f6d", "font_style": "italic" },
          "comment.doc": { "color": "#6b8e9e", "font_style": "italic" },
          "constant": { "color": "#ff0066" },
          "constructor": { "color": "#26c6da" },
          "embedded": { "color": "#b3e5fc" },
          "emphasis": { "color": "#26c6da", "font_style": "italic" },
          "emphasis.strong": { "color": "#ff0066", "font_weight": 700 },
          "enum": { "color": "#ffa726" },
          "function": { "color": "#00d4aa" },
          "hint": {
            "color": "#4a5f6d",
            "font_style": "italic",
            "font_weight": 700
          },
          "keyword": { "color": "#ff0066" },
          "label": { "color": "#00ff9f" },
          "link_text": { "color": "#26c6da", "font_style": "italic" },
          "link_uri": { "color": "#00d4aa" },
          "number": { "color": "#ffa726" },
          "operator": { "color": "#ff0066" },
          "predictive": { "color": "#6b8e9e", "font_style": "italic" },
          "preproc": { "color": "#b3e5fc" },
          "primary": { "color": "#b3e5fc" },
          "property": { "color": "#80deea" },
          "punctuation": { "color": "#6b8e9e" },
          "punctuation.bracket": { "color": "#80deea" },
          "punctuation.delimiter": { "color": "#6b8e9e" },
          "punctuation.list_marker": { "color": "#ff0066" },
          "punctuation.special": { "color": "#00ff9f" },
          "string": { "color": "#00ff9f" },
          "string.escape": { "color": "#00d4aa" },
          "string.regex": { "color": "#26c6da" },
          "string.special": { "color": "#00d4aa" },
          "string.special.symbol": { "color": "#00ff9f" },
          "tag": { "color": "#ff0066" },
          "text.literal": { "color": "#00ff9f" },
          "title": { "color": "#00d4aa", "font_weight": 700 },
          "type": { "color": "#26c6da" },
          "variable": { "color": "#b3e5fc" },
          "variable.special": { "color": "#ff0066" },
          "variant": { "color": "#26c6da" }
        },
        "terminal.ansi.black": "#0a0e14",
        "terminal.ansi.red": "#ff0066",
        "terminal.ansi.green": "#00ff9f",
        "terminal.ansi.yellow": "#ffa726",
        "terminal.ansi.blue": "#26c6da",
        "terminal.ansi.magenta": "#ab47bc",
        "terminal.ansi.cyan": "#00d4aa",
        "terminal.ansi.white": "#b3e5fc",
        "terminal.ansi.bright_black": "#4a5f6d",
        "terminal.ansi.bright_red": "#ff3385",
        "terminal.ansi.bright_green": "#33ffb8",
        "terminal.ansi.bright_yellow": "#ffb84d",
        "terminal.ansi.bright_blue": "#4dd0e1",
        "terminal.ansi.bright_magenta": "#ce93d8",
        "terminal.ansi.bright_cyan": "#80deea",
        "terminal.ansi.bright_white": "#e1f5fe"
      }
    }
