        "editor.document_highlight.write_background": "{{colors.tertiary.default.hex}}33",

        "link_text.hover": "{{colors.primary.default.hex}}",

        "conflict": "#ffa726",
        "conflict.background": "#ffa72622",
        "conflict.border": "#ffa726",
